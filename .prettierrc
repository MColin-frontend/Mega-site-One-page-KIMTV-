{
  "semi": false,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "es5",
  "printWidth": 100,
  "plugins": [
    "@ianvs/prettier-plugin-sort-imports",
    "prettier-plugin-tailwindcss"
  ],

  "importOrder": [
    "",
    "^(react|react-dom)(.*)$",
    "^(next)(.*)$",
    "<THIRD_PARTY_MODULES>",
    "",
    "^@/server/(.*)$",
    "^@/lib/(.*)$",
    "^@/hooks/(.*)$",
    "",
    "^@/i18n(.*)$",
    "^@/config/(.*)$",
    "^@/constants/(.*)$",
    "^@/enums/(.*)$",
    "^@/types(.*)$",
    "^@/models/(.*)$",
    "",
    "^@/features/(.*)$",
    "^@/components/(.*)$",
    "",
    "^@icons$",
    "^@assets/(.*)$",
    "",
    "^\\.(.*)$",
    "",
    "^.+\\.css$"
  ]
}
