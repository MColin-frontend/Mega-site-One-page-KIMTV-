# ---------------------------------------------------------------------------
# Biến môi trường mega-site — COPY file này thành `.env` rồi điền giá trị.
#   cp .env.example .env
# `.env` đã bị .gitignore (không commit). File `.env.example` này CHỈ là mẫu,
# không đặt secret thật vào đây.
# ---------------------------------------------------------------------------

# === Server runtime (đọc lúc CHẠY trên server — KHÔNG inline vào client bundle) ===

# Backend KimTV (Java) — base URL đã bao gồm prefix `/java`.
API_BASE_URL=https://kimtv.net/java

# Origin/Referer gửi kèm request (backend/Cloudflare kiểm tra nguồn).
API_ORIGIN=https://kimtv.net

# Timeout mỗi request (ms). Bỏ trống để dùng mặc định 15000.
API_TIMEOUT_MS=15000

# === Client build-time (INLINE lúc `next build` — phải truyền qua Docker build-arg) ===

# WebSocket chat. prod: wss://ws.kimtv.org | dev: wss://ws-dev.kimtv.org
NEXT_PUBLIC_WS_BASE_URL=wss://ws.kimtv.org
